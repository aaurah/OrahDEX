{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && fuser -k ${PORT:-8080}/tcp 2>/dev/null; sleep 2; node ./build.mjs && exec node --enable-source-maps --max-old-space-size=512 ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --max-old-space-size=512 ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^7.0.11",
    "esbuild": "^0.28.0",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "4.0.0"
  }
}
