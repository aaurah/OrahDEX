modules = ["nodejs-20", "web", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/bsv-dex"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "pnpm --filter @workspace/api-server run start & PORT=5000 pnpm --filter @workspace/bsv-dex run serve"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/bsv-dex run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OrahDEX Frontend"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "OrahDEX Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/bsv-dex run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VAULT_CONTRACT_ADDRESS = "0x67C7f23eE49B6417661748F23F743C0B274039e2"
VAULT_CHAIN_ID = "8453"
VITE_REOWN_PROJECT_ID = "04663615251cf13fb1b043d754e7a17f"
STRIPE_ENV = "development"

[[ports]]
localPort = 8080
externalPort = 8080
